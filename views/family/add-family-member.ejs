<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/family.css"/>
</head>
<body>

  <nav class="top-nav">
    <div class="nav-inner">
      <a href="/dashboard" class="logo">
        <svg width="30" height="30" viewBox="0 0 38 38" fill="none">
          <rect width="38" height="38" rx="10" fill="#1b4332"/>
          <path d="M19 7L9 14v16h6v-8h8v8h6V14L19 7z" fill="#d4a853"/>
        </svg>
        <span>GramSeva</span>
      </a>
      <div class="nav-right">
        <span class="owner-name"><%= typeof owner !== 'undefined' && owner ? owner.name : 'Owner' %></span>
        <a href="/logout" class="logout-btn">Logout</a>
      </div>
    </div>
  </nav>

  <div class="page-wrap">
    <a href="/family/<%= familyId %>/detail" class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Back to Family
    </a>

    <div class="form-card">

      <!-- Header -->
      <div class="form-header">
        <div class="header-icon green">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
            <line x1="19" y1="8" x2="19" y2="14"/>
            <line x1="22" y1="11" x2="16" y2="11"/>
          </svg>
        </div>
        <div>
          <h4 class="form-title">Add Family Member</h4>
          <p class="form-sub">Adding member to <strong><%= headName %></strong>'s family</p>
        </div>
      </div>

      <!-- Errors -->
      <% if (errors.length > 0) { %>
        <div class="alert alert-danger rounded-3">
          <% errors.forEach(e => { %><p class="mb-0 small"><%= e.msg %></p><% }) %>
        </div>
      <% } %>

      <form action="/family/<%= familyId %>/members/add" method="POST" enctype="multipart/form-data" id="memberForm">

        <!-- Member Details -->
        <div class="sec-label"><span class="sec-num">01</span> Member Details</div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Full Name <span class="req">*</span></label>
          <input type="text" name="name" class="form-control ci" placeholder="Member full name" value="<%= formData.name || '' %>" required/>
        </div>

        <div class="row">
          <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">Age <span class="req">*</span></label>
            <input type="number" name="age" class="form-control ci" placeholder="Age" min="0" max="120" value="<%= formData.age || '' %>" required/>
          </div>
          <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">Relation <span class="req">*</span></label>
            <select name="relation" class="form-select ci" required>
              <option value="" disabled selected>-- Select --</option>
              <option value="Spouse"   <%= formData.relation === 'Spouse'   ? 'selected' : '' %>>Spouse</option>
              <option value="Son"      <%= formData.relation === 'Son'      ? 'selected' : '' %>>Son</option>
              <option value="Daughter" <%= formData.relation === 'Daughter' ? 'selected' : '' %>>Daughter</option>
              <option value="Father"   <%= formData.relation === 'Father'   ? 'selected' : '' %>>Father</option>
              <option value="Mother"   <%= formData.relation === 'Mother'   ? 'selected' : '' %>>Mother</option>
              <option value="Brother"  <%= formData.relation === 'Brother'  ? 'selected' : '' %>>Brother</option>
              <option value="Sister"   <%= formData.relation === 'Sister'   ? 'selected' : '' %>>Sister</option>
              <option value="Other"    <%= formData.relation === 'Other'    ? 'selected' : '' %>>Other</option>
            </select>
          </div>
          <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">Phone</label>
            <input type="tel" name="phone" class="form-control ci" placeholder="Optional" value="<%= formData.phone || '' %>" maxlength="10"/>
          </div>
        </div>

        <div class="mb-4">
          <label class="form-label fw-semibold">Occupation</label>
          <input type="text" name="occupation" class="form-control ci" placeholder="e.g. Student, Farmer (optional)" value="<%= formData.occupation || '' %>"/>
        </div>

        <!-- Member Photo -->
        <div class="sec-label"><span class="sec-num">02</span> Member Photo <span class="optional-lbl">Optional</span></div>

        <div class="mb-4">
          <div class="upload-box" id="uploadBox" onclick="document.getElementById('memberPhotoInput').click()">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="upload-icon">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <p class="upload-hint" id="uploadHint">Click to upload member photo</p>
            <img id="memberPhotoPreview" src="" alt="" class="upload-preview"/>
          </div>
          <input type="file" name="member_photo" id="memberPhotoInput" accept="image/jpeg,image/png" style="display:none"/>
        </div>

        <div class="form-footer">
          <a href="/family/<%= familyId %>/detail" class="btn btn-outline-secondary px-4">Cancel</a>
          <button type="submit" class="btn-submit" id="submitBtn">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="me-2"><polyline points="20 6 9 17 4 12"/></svg>
            Save Member
          </button>
        </div>

      </form>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Photo preview
    document.getElementById("memberPhotoInput").addEventListener("change", function() {
      const file = this.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = e => {
        document.getElementById("memberPhotoPreview").src = e.target.result;
        document.getElementById("memberPhotoPreview").classList.add("visible");
        document.getElementById("uploadBox").classList.add("has-image");
      };
      reader.readAsDataURL(file);
    });
    // Phone digits only
    const ph = document.querySelector('input[name="phone"]');
    if (ph) ph.addEventListener("input", () => { ph.value = ph.value.replace(/\D/g,"").slice(0,10); });
    // Disable on submit
    document.getElementById("memberForm").addEventListener("submit", function() {
      const btn = document.getElementById("submitBtn");
      btn.disabled = true;
      btn.textContent = "Saving...";
    });
  </script>
</body>
</html>
