<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/family.css"/>
</head>
<body>

  <nav class="top-nav">
    <div class="nav-inner">
      <a href="/dashboard" class="logo">
        <svg width="30" height="30" viewBox="0 0 38 38" fill="none">
          <rect width="38" height="38" rx="10" fill="#1b4332"/>
          <path d="M19 7L9 14v16h6v-8h8v8h6V14L19 7z" fill="#d4a853"/>
        </svg>
        <span>GramSeva</span>
      </a>
      <div class="nav-right">
        <span class="owner-name"><%= typeof owner !== 'undefined' && owner ? owner.name : 'Owner' %></span>
        <a href="/logout" class="logout-btn">Logout</a>
      </div>
    </div>
  </nav>

  <div class="page-wrap">
    <div class="form-card">

      <!-- Header -->
      <div class="form-header">
        <div class="header-icon teal">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="5" width="20" height="14" rx="2"/>
            <path d="M2 10h20"/>
          </svg>
        </div>
        <div>
          <h4 class="form-title">Family ID Proof</h4>
          <p class="form-sub">Step 2 of 3 — Head identity document</p>
        </div>
        <div class="step-pill">2 / 3</div>
      </div>

      <!-- Banner -->
      <div class="success-banner">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        Family head saved. Now add ID proof for <strong><%= headName %></strong>
      </div>

      <!-- Errors -->
      <% if (errors.length > 0) { %>
        <div class="alert alert-danger rounded-3 mt-3">
          <% errors.forEach(e => { %><p class="mb-0 small"><%= e.msg %></p><% }) %>
        </div>
      <% } %>

      <form action="/family/<%= familyId %>/id-proof" method="POST" enctype="multipart/form-data" id="proofForm">

        <div class="sec-label"><span class="sec-num">01</span> Proof Details</div>

        <div class="mb-3">
          <label class="form-label fw-semibold">ID Proof Type <span class="req">*</span></label>
          <select name="id_proof_type" class="form-select ci" required>
            <option value="" disabled selected>-- Select proof type --</option>
            <option value="Aadhaar">Aadhaar Card</option>
            <option value="Voter ID">Voter ID</option>
            <option value="PAN">PAN Card</option>
            <option value="Passport">Passport</option>
            <option value="Driving Licence">Driving Licence</option>
          </select>
        </div>

        <div class="mb-4">
          <label class="form-label fw-semibold">ID Proof Number <span class="req">*</span></label>
          <input type="text" name="id_proof_number" class="form-control ci" placeholder="Enter document number" required/>
        </div>

        <div class="sec-label"><span class="sec-num">02</span> Upload Proof Image</div>

        <div class="mb-4">
          <div class="upload-box" id="uploadBox" onclick="document.getElementById('proofInput').click()">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="upload-icon">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <p class="upload-hint" id="uploadHint">Click to upload proof image</p>
            <img id="proofPreview" src="" alt="" class="upload-preview"/>
          </div>
          <input type="file" name="proof_image" id="proofInput" accept="image/jpeg,image/png" required style="display:none"/>
        </div>

        <div class="form-footer">
          <a href="javascript:history.back()" class="btn btn-outline-secondary px-4">Back</a>
          <button type="submit" class="btn-submit" id="submitBtn">
            Save &amp; Add Members
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ms-2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>

      </form>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const proofInput = document.getElementById("proofInput");
    proofInput.addEventListener("change", function() {
      const file = this.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = e => {
        document.getElementById("proofPreview").src = e.target.result;
        document.getElementById("proofPreview").classList.add("visible");
        document.getElementById("uploadBox").classList.add("has-image");
      };
      reader.readAsDataURL(file);
    });
    document.getElementById("proofForm").addEventListener("submit", function() {
      const btn = document.getElementById("submitBtn");
      btn.disabled = true;
      btn.textContent = "Saving...";
    });
  </script>
</body>
</html>
