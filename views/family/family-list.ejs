<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/family.css"/>
</head>
<body>

  <nav class="top-nav">
    <div class="nav-inner">
      <a href="/dashboard" class="logo">
        <svg width="30" height="30" viewBox="0 0 38 38" fill="none">
          <rect width="38" height="38" rx="10" fill="#1b4332"/>
          <path d="M19 7L9 14v16h6v-8h8v8h6V14L19 7z" fill="#d4a853"/>
        </svg>
        <span>GramSeva</span>
      </a>
      <div class="nav-right">
        <span class="owner-name"><%= typeof owner !== 'undefined' && owner ? owner.name : 'Owner' %></span>
        <a href="/logout" class="logout-btn">Logout</a>
      </div>
    </div>
  </nav>

  <div class="page-wrap">

    <div class="page-header">
      <div>
        <a href="/dashboard" class="back-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          Dashboard
        </a>
        <h4 class="page-title">Family Tenants</h4>
        <p class="page-sub">Total: <strong><%= families.length %></strong> &nbsp;|&nbsp; Active: <strong><%= families.filter(f=>f.status==='active').length %></strong></p>
      </div>
      <a href="/family/add-head" class="btn-add-member">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add New Family
      </a>
    </div>

    <!-- Search -->
    <div class="search-wrap mb-4">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="s-icon">
        <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
      </svg>
      <input type="text" id="searchInput" placeholder="Search by name or phone..." oninput="filterList()"/>
    </div>

    <% if (families.length === 0) { %>
      <div class="empty-box">
        <div class="empty-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#74c69d" stroke-width="1.5">
            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
          </svg>
        </div>
        <p class="empty-title">No families yet</p>
        <p class="empty-sub">Click "Add New Family" to get started.</p>
        <a href="/family/add" class="btn-add-member mt-3">Add First Family</a>
      </div>
    <% } else { %>

      <div class="tenant-list" id="familyList">
        <% families.forEach((fam, i) => { %>
          <div class="tenant-row" data-name="<%= fam.head_name.toLowerCase() %>" data-phone="<%= fam.phone %>">

            <div class="row-serial"><%= i + 1 %></div>

            <!-- Head photo -->
            <div class="row-photo">
              <% if (fam.head_photo && fam.head_photo.data) { %>
                <img src="data:<%= fam.head_photo.mimetype %>;base64,<%= fam.head_photo.data.toString('base64') %>" class="row-img" alt="<%= fam.head_name %>"/>
              <% } else { %>
                <div class="row-img-placeholder">
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#74c69d" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
                </div>
              <% } %>
            </div>

            <!-- Info -->
            <div class="row-info">
              <div class="row-name"><%= fam.head_name %></div>
              <div class="row-meta">
                <span>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .84h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 8.64a16 16 0 006.29 6.29l1.16-1.16a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                  <%= fam.phone %>
                </span>
                <span>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
                  <%= fam.total_members %> member<%= fam.total_members !== 1 ? 's' : '' %>
                </span>
                <span><%= fam.occupation %></span>
              </div>
            </div>

            <!-- Status + View -->
            <div class="row-right">
              <span class="status-dot <%= fam.status === 'active' ? 'dot-active' : 'dot-inactive' %>"><%= fam.status %></span>
              <a href="/family/<%= fam._id %>/detail" class="view-btn">
                View
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>

          </div>
        <% }) %>
      </div>

      <div id="noResults" class="no-results" style="display:none">No families found.</div>
    <% } %>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function filterList() {
      const q = document.getElementById("searchInput").value.toLowerCase();
      const rows = document.querySelectorAll(".tenant-row");
      let count = 0;
      rows.forEach(r => {
        const match = r.dataset.name.includes(q) || r.dataset.phone.includes(q);
        r.style.display = match ? "flex" : "none";
        if (match) count++;
      });
      document.getElementById("noResults").style.display = count === 0 ? "block" : "none";
    }
  </script>
</body>
</html>
