<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/edit-tenant.css"/>
</head>
<body>

  <!-- NAVBAR -->
  <nav class="top-nav">
    <div class="nav-inner">
      <a href="/dashboard" class="logo">
        <svg width="30" height="30" viewBox="0 0 38 38" fill="none">
          <rect width="38" height="38" rx="10" fill="#1b4332"/>
          <path d="M19 7L9 14v16h6v-8h8v8h6V14L19 7z" fill="#d4a853"/>
        </svg>
        <span>GramSeva</span>
      </a>
      <div class="nav-right">
        <span class="owner-name">
          <%= typeof owner !== 'undefined' && owner ? owner.name : 'Owner' %>
        </span>
        <a href="/logout" class="logout-btn">Logout</a>
      </div>
    </div>
  </nav>

  <div class="page-wrap">

    <!-- Back -->
    <a href="/single/<%= tenant._id %>/detail" class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
      Back to Tenant Details
    </a>

    <div class="edit-card">

      <!-- Header -->
      <div class="edit-header">
        <div class="edit-header-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
        </div>
        <div>
          <h4 class="edit-title">Edit Tenant</h4>
          <p class="edit-sub">Update details for <strong><%= tenant.name %></strong></p>
        </div>
      </div>

      <!-- Validation Errors -->
      <% if (errors.length > 0) { %>
        <div class="alert alert-danger rounded-3 mx-0 mt-0 mb-4">
          <% errors.forEach(err => { %>
            <p class="mb-0 small"><%= err.msg %></p>
          <% }) %>
        </div>
      <% } %>

      <!--
        POST method with ?_method=PUT override
        because HTML forms only support GET and POST
        We use method-override package to handle PUT
      -->
      <form
        action="/single/<%= tenant._id %>?_method=PUT"
        method="POST"
        enctype="multipart/form-data"
        id="editForm"
      >

        <!-- ── SECTION 1: Personal Details ── -->
        <div class="section-label">
          <span class="section-num">01</span> Personal Details
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">
            Full Name <span class="req">*</span>
          </label>
          <input
            type="text"
            name="name"
            class="form-control custom-input"
            value="<%= tenant.name %>"
            required
          />
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">
              Phone Number <span class="req">*</span>
            </label>
            <input
              type="tel"
              name="phone"
              class="form-control custom-input"
              value="<%= tenant.phone %>"
              maxlength="10"
              required
            />
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">
              Occupation <span class="req">*</span>
            </label>
            <input
              type="text"
              name="occupation"
              class="form-control custom-input"
              value="<%= tenant.occupation %>"
              required
            />
          </div>
        </div>

        <div class="mb-4">
          <label class="form-label fw-semibold">
            Permanent Address <span class="req">*</span>
          </label>
          <textarea
            name="permanent_address"
            class="form-control custom-input"
            rows="2"
            required
          ><%= tenant.permanent_address %></textarea>
        </div>

        <!-- ── SECTION 2: Update Tenant Photo (optional) ── -->
        <div class="section-label">
          <span class="section-num">02</span> Update Tenant Photo
          <span class="optional-tag">Optional</span>
        </div>

        <!-- Show current photo -->
        <div class="current-photo-row">
          <div class="current-photo-wrap">
            <% if (tenant.tenant_photo && tenant.tenant_photo.data) { %>
              <img
                src="data:<%= tenant.tenant_photo.mimetype %>;base64,<%= tenant.tenant_photo.data.toString('base64') %>"
                alt="Current Photo"
                class="current-photo"
                id="photoPreview"
              />
            <% } else { %>
              <div class="photo-placeholder" id="photoPreview">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#74c69d" stroke-width="1.5">
                  <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              </div>
            <% } %>
          </div>
          <div class="current-photo-info">
            <p class="current-label">Current photo</p>
            <p class="current-hint">Upload a new photo to replace it. Leave empty to keep the current photo.</p>
            <label class="upload-trigger" for="tenantPhotoInput">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
              Choose New Photo
            </label>
            <input
              type="file"
              name="tenant_photo"
              id="tenantPhotoInput"
              accept="image/jpeg,image/png"
              style="display:none"
            />
          </div>
        </div>

        <!-- ── SECTION 3: Update ID Proof (optional) ── -->
        <div class="section-label">
          <span class="section-num">03</span> Update ID Proof
          <span class="optional-tag">Optional</span>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">ID Proof Type</label>
            <select name="id_proof_type" class="form-select custom-input">
              <option value="">-- Keep existing --</option>
              <option value="Aadhaar"         <%= idProof && idProof.id_proof_type === 'Aadhaar'         ? 'selected' : '' %>>Aadhaar Card</option>
              <option value="Voter ID"        <%= idProof && idProof.id_proof_type === 'Voter ID'        ? 'selected' : '' %>>Voter ID</option>
              <option value="PAN"             <%= idProof && idProof.id_proof_type === 'PAN'             ? 'selected' : '' %>>PAN Card</option>
              <option value="Passport"        <%= idProof && idProof.id_proof_type === 'Passport'        ? 'selected' : '' %>>Passport</option>
              <option value="Driving Licence" <%= idProof && idProof.id_proof_type === 'Driving Licence' ? 'selected' : '' %>>Driving Licence</option>
            </select>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">ID Proof Number</label>
            <input
              type="text"
              name="id_proof_number"
              class="form-control custom-input"
              placeholder="Leave empty to keep existing"
              value="<%= idProof ? idProof.id_proof_number : '' %>"
            />
          </div>
        </div>

        <!-- Current ID proof image + upload new -->
        <div class="current-photo-row mb-4">
          <div class="current-photo-wrap">
            <% if (idProof && idProof.proof_image && idProof.proof_image.data) { %>
              <img
                src="data:<%= idProof.proof_image.mimetype %>;base64,<%= idProof.proof_image.data.toString('base64') %>"
                alt="ID Proof"
                class="current-photo id-img"
                id="proofPreview"
              />
            <% } else { %>
              <div class="photo-placeholder" id="proofPreview">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#74c69d" stroke-width="1.5">
                  <rect x="2" y="5" width="20" height="14" rx="2"/>
                  <path d="M2 10h20"/>
                </svg>
              </div>
            <% } %>
          </div>
          <div class="current-photo-info">
            <p class="current-label">Current ID proof image</p>
            <p class="current-hint">Upload a new image to replace. Leave empty to keep current.</p>
            <label class="upload-trigger" for="proofImageInput">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
              Choose New Proof Image
            </label>
            <input
              type="file"
              name="proof_image"
              id="proofImageInput"
              accept="image/jpeg,image/png"
              style="display:none"
            />
          </div>
        </div>

        <!-- ── SUBMIT ── -->
        <div class="edit-footer">
          <a href="/single/<%= tenant._id %>/detail" class="btn btn-outline-secondary px-4">
            Cancel
          </a>
          <button type="submit" class="btn-save" id="saveBtn">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            Save Changes
          </button>
        </div>

      </form>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/edit-tenant.js"></script>
</body>
</html>
