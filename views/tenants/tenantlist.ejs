<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/tenantlist.css"/>
</head>
<body>

  <!-- NAVBAR -->
  <nav class="top-nav">
    <div class="nav-inner">
      <a href="/dashboard" class="logo">
        <svg width="30" height="30" viewBox="0 0 38 38" fill="none">
          <rect width="38" height="38" rx="10" fill="#1b4332"/>
          <path d="M19 7L9 14v16h6v-8h8v8h6V14L19 7z" fill="#d4a853"/>
        </svg>
        <span>GramSeva</span>
      </a>
      <div class="nav-right">
        <span class="owner-name">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <%= typeof owner !== 'undefined' && owner ? owner.name : 'Owner' %>
        </span>
        <a href="/logout" class="logout-btn">Logout</a>
      </div>
    </div>
  </nav>

  <!-- PAGE -->
  <div class="page-wrap">

    <!-- Page Header -->
    <div class="page-header">
      <div>
        <a href="/dashboard" class="back-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Dashboard
        </a>
        <h4 class="page-title">Single Tenant List</h4>
        <p class="page-sub">
          Total: <strong><%= tenants.length %></strong> &nbsp;|&nbsp;
          Active: <strong><%= tenants.filter(t => t.status === 'active').length %></strong>
        </p>
      </div>
      <a href="/single/add" class="btn-add">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Add New Tenant
      </a>
    </div>

    <!-- Search -->
    <div class="search-wrap">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="s-icon">
        <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
      </svg>
      <input
        type="text"
        id="searchInput"
        placeholder="Search by name, phone or occupation..."
        oninput="filterTenants()"
      />
    </div>

    <!-- List -->
    <% if (tenants.length === 0) { %>
      <div class="empty-box">
        <div class="empty-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#74c69d" stroke-width="1.5">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </div>
        <p class="empty-title">No tenants yet</p>
        <p class="empty-sub">Click "Add New Tenant" to register your first tenant.</p>
        <a href="/single/add" class="btn-add mt-3">Add First Tenant</a>
      </div>
    <% } else { %>

      <div class="tenant-list" id="tenantList">
        <% tenants.forEach((tenant, index) => { %>

          <!-- Blueprint: [Photo | Name, phone, occupation, address] as a row -->
          <div
            class="tenant-row"
            data-name="<%= tenant.name.toLowerCase() %>"
            data-phone="<%= tenant.phone %>"
            data-occ="<%= tenant.occupation.toLowerCase() %>"
          >
            <!-- Serial number -->
            <div class="row-serial"><%= index + 1 %></div>

            <!-- Photo (left side as in blueprint) -->
            <div class="row-photo">
              <% if (tenant.tenant_photo && tenant.tenant_photo.data) { %>
                <img
                  src="data:<%= tenant.tenant_photo.mimetype %>;base64,<%= tenant.tenant_photo.data.toString('base64') %>"
                  alt="<%= tenant.name %>"
                  class="row-img"
                />
              <% } else { %>
                <div class="row-img-placeholder">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#74c69d" stroke-width="1.5">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                  </svg>
                </div>
              <% } %>
            </div>

            <!-- Info (right side as in blueprint) -->
            <div class="row-info">
              <div class="row-name"><%= tenant.name %></div>
              <div class="row-meta">
                <span>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .84h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.64a16 16 0 006.29 6.29l1.16-1.16a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
                  </svg>
                  <%= tenant.phone %>
                </span>
                <span>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="7" width="20" height="14" rx="2"/>
                    <path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/>
                  </svg>
                  <%= tenant.occupation %>
                </span>
                <span class="row-address">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  <%= tenant.permanent_address %>
                </span>
              </div>
            </div>

            <!-- Status + View button (right edge) -->
            <div class="row-right">
              <span class="status-dot <%= tenant.status === 'active' ? 'dot-active' : 'dot-inactive' %>">
                <%= tenant.status === 'active' ? 'Active' : 'Inactive' %>
              </span>
              <!-- Arrow to Overall Info Page as in blueprint -->
              <a href="/single/<%= tenant._id %>/detail" class="view-btn">
                View
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>

          </div>

        <% }) %>
      </div>

      <div id="noResults" class="no-results" style="display:none">
        No tenants found matching your search.
      </div>

    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function filterTenants() {
      const q     = document.getElementById("searchInput").value.toLowerCase();
      const rows  = document.querySelectorAll(".tenant-row");
      let   count = 0;
      rows.forEach(r => {
        const match = r.dataset.name.includes(q) || r.dataset.phone.includes(q) || r.dataset.occ.includes(q);
        r.style.display = match ? "flex" : "none";
        if (match) count++;
      });
      document.getElementById("noResults").style.display = count === 0 ? "block" : "none";
    }
  </script>
</body>
</html>
