<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>

  <!-- Custom CSS — separate file -->
  <link rel="stylesheet" href="/css/add-single.css"/>
</head>
<body>

  <div class="container">
    <div class="form-card">

      <!-- Page Header -->
      <div class="form-header">
        <a href="javascript:history.back()" class="back-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
        </a>
        <div>
          <h4 class="form-title">Add Single Tenant</h4>
          <p class="form-subtitle">Step 1 of 2 — Personal details &amp; photo</p>
        </div>
        <div class="step-pill">1 / 2</div>
      </div>

      <!-- Validation Errors -->
      <% if (errors.length > 0) { %>
        <div class="alert alert-danger rounded-3">
          <% errors.forEach(err => { %>
            <p class="mb-0 small"><%= err.msg %></p>
          <% }) %>
        </div>
      <% } %>

      <!-- Form -->
      <form
        action="/single/add"
        method="POST"
        enctype="multipart/form-data"
        id="tenantForm"
        novalidate
      >

        <!-- ── SECTION 1: Personal Details ── -->
        <div class="section-label">
          <span class="section-icon">01</span> Personal Details
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">
            Full Name <span class="req">*</span>
          </label>
          <input
            type="text"
            name="name"
            class="form-control custom-input"
            placeholder="e.g. Ramesh Vitthal Patil"
            value="<%= formData.name || '' %>"
            required
          />
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">
              Phone Number <span class="req">*</span>
            </label>
            <input
              type="tel"
              name="phone"
              class="form-control custom-input"
              placeholder="10-digit mobile number"
              value="<%= formData.phone || '' %>"
              maxlength="10"
              pattern="[0-9]{10}"
              required
            />
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">
              Occupation <span class="req">*</span>
            </label>
            <input
              type="text"
              name="occupation"
              class="form-control custom-input"
              placeholder="e.g. Farmer, Labour, Teacher"
              value="<%= formData.occupation || '' %>"
              required
            />
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">
            Permanent Address <span class="req">*</span>
          </label>
          <textarea
            name="permanent_address"
            class="form-control custom-input"
            rows="2"
            placeholder="Village, Taluka, District, Pin Code"
            required
          ><%= formData.permanent_address || '' %></textarea>
        </div>

        <!-- ── SECTION 2: Tenant Photo Upload ── -->
        <div class="section-label">
          <span class="section-icon">02</span> Tenant Photo
        </div>

        <div class="mb-4">
          <label class="form-label fw-semibold">
            Upload Photo <span class="req">*</span>
            <span class="text-muted fw-normal small ms-1">(JPEG or PNG, max 5MB)</span>
          </label>

          <div class="upload-box" id="uploadBox" onclick="document.getElementById('tenantPhotoInput').click()">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="upload-icon">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <p class="upload-hint" id="uploadHint">Click to upload tenant photo</p>
            <img id="tenantPhotoPreview" src="" alt="Preview" class="upload-preview"/>
          </div>

          <!-- hidden file input — name must match multer field exactly -->
          <input
            type="file"
            name="tenant_photo"
            id="tenantPhotoInput"
            accept="image/jpeg,image/png"
            required
            style="display:none"
          />
        </div>

        <!-- ── SECTION 3: Live Photo Capture ── -->
        <div class="section-label">
          <span class="section-icon">03</span> Live Photo Capture
        </div>

        <p class="text-muted small mb-3">
          Take a real-time photo using the device camera. This is required for verification.
        </p>

        <div class="camera-section mb-4">

          <!-- Camera controls -->
          <div class="camera-controls" id="cameraControls">
            <button type="button" class="btn btn-outline-success btn-sm" id="openCameraBtn">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1">
                <path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/>
                <circle cx="12" cy="13" r="4"/>
              </svg>
              Open Camera
            </button>
          </div>

          <!-- Video stream -->
          <div class="camera-stream" id="cameraBox">
            <video id="cameraPreview" autoplay playsinline class="camera-video"></video>
            <div class="camera-actions">
              <button type="button" class="btn btn-success btn-sm" id="captureBtn">
                Capture Photo
              </button>
              <button type="button" class="btn btn-outline-secondary btn-sm ms-2" id="stopBtn">
                Cancel
              </button>
            </div>
          </div>

          <!-- Captured result -->
          <div class="camera-result" id="cameraResult">
            <img id="capturedImg" src="" alt="Captured live photo" class="captured-img"/>
            <div class="captured-info">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1D9E75" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span id="captureStatus">Live photo captured</span>
              <button type="button" class="btn btn-link btn-sm p-0 ms-2 text-danger" id="retakeBtn">Retake</button>
            </div>
          </div>

          <!-- Hidden input — carries base64 to server -->
          <input type="hidden" name="live_photo_base64" id="livePhotoData"/>
        </div>

        <!-- ── SUBMIT ── -->
        <div class="form-footer">
          <a href="javascript:history.back()" class="btn btn-outline-secondary px-4">
            Cancel
          </a>
          <button type="submit" class="btn btn-submit px-5" id="submitBtn">
            Save &amp; Continue to ID Proof
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ms-2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </button>
        </div>

      </form>
    </div>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <!-- Custom JS — separate file -->
  <script src="/js/add-single.js"></script>

</body>
</html>
