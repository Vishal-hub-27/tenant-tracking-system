<!DOCTYPE html>
<html lang="en">
<head>
    <title>Village Tenant Dashboard</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<!-- 🔹 Navbar -->
<nav class="navbar navbar-dark bg-dark px-3">
    
    <div class="d-flex align-items-center">
        <img src="/images/logo.png" width="40" height="40" class="me-2">
        <span class="text-white fw-bold">Village Tenant</span>
    </div>

    <div class="d-flex align-items-center gap-3">

        <span class="text-white">
            <i class="bi bi-person-circle"></i> Vishal
        </span>

        <!-- ✅ Sign Out Button -->
        <a href="/logout" class="btn btn-danger btn-sm">
            <i class="bi bi-box-arrow-right"></i> Sign Out
        </a>

    </div>
</nav>

<!-- 🔹 Layout -->
<div class="container-fluid">
    <div class="row">

        <!-- 🔹 Sidebar -->
        <div class="col-md-2 sidebar p-3">

            <h5 class="text-white mb-4">Menu</h5>

            <a href="#" class="nav-link text-white">
                <i class="bi bi-house-door"></i> Dashboard
            </a>

            <!-- ❌ Tenant Removed -->

            <a href="#" class="nav-link text-white">
                <i class="bi bi-info-circle"></i> About
            </a>

            <a href="#" class="nav-link text-white mt-5">
                <i class="bi bi-headset"></i> Support
            </a>

        </div>

        <!-- 🔹 Content -->
        <div class="col-md-10 p-4">

            <h3 class="mb-4">Dashboard</h3>

            <div class="row g-4">

                <!-- 🔹 Single Person Card -->
                <div class="col-md-6">
                    <div class="card shadow text-center p-4">

                        <i class="bi bi-person-plus display-4 text-primary"></i>

                        <h4 class="mt-3">Single Person</h4>
                        <p>Add or manage single tenant</p>
                   <div class="d-flex justify-content-center gap-2">

    <!-- Add Single -->
    <form action="single/add" method="GET">
        <button type="submit" class="btn btn-primary">
            Add New
        </button>
    </form>

    <!-- Existing Single -->
    <form action="single" method="GET">
        <button type="submit" class="btn btn-outline-primary">
            Existing
        </button>
    </form>

</div>


                    </div>
                </div>

                <!-- 🔹 Family Card -->
                <div class="col-md-6">
                    <div class="card shadow text-center p-4">

                        <i class="bi bi-people-fill display-4 text-success"></i>

                        <h4 class="mt-3">Family</h4>
                        <p>Add or manage family tenants</p>
                     <div class="d-flex justify-content-center gap-2">

    <!-- Add Family -->
    <form action="family/add-head" method="GET">
        <button class="btn btn-success">
            Add New
        </button>
    </form>
  
    <!-- Existing Family -->
    <form action="/family" method="GET">
        <button class="btn btn-outline-success">
            Existing
        </button>
    </form>

</div>

                    </div>
                </div>

            </div>

        </div>

    </div>
</div>

<!-- 🔹 Footer -->
<footer class="bg-dark text-white text-center p-2 mt-3">
    © 2026 Village Tenant System
</footer>

</body>
</html>