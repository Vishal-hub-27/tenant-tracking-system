<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Error — GramSeva</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <style>
    body {
      background : #f4f6f3;
      min-height : 100vh;
      display    : flex;
      align-items: center;
      justify-content: center;
    }
    .error-card {
      background   : #ffffff;
      border-radius: 20px;
      padding      : 48px 36px;
      max-width    : 480px;
      width        : 100%;
      text-align   : center;
      box-shadow   : 0 4px 24px rgba(27,67,50,.10);
    }
    .error-icon {
      width          : 72px;
      height         : 72px;
      border-radius  : 50%;
      background     : #fdecea;
      display        : flex;
      align-items    : center;
      justify-content: center;
      margin         : 0 auto 24px;
    }
    .error-code {
      font-size    : 56px;
      font-weight  : 700;
      color        : #e2e8f0;
      line-height  : 1;
      margin-bottom: 8px;
    }
    .error-title {
      font-size    : 20px;
      font-weight  : 700;
      color        : #1b4332;
      margin-bottom: 10px;
    }
    .error-message {
      font-size    : 14px;
      color        : #718096;
      margin-bottom: 32px;
      line-height  : 1.7;
    }
    .btn-green {
      background   : #1b4332;
      color        : #d4a853;
      border       : none;
      font-weight  : 700;
      border-radius: 10px;
      padding      : 10px 28px;
      transition   : background .2s;
      text-decoration: none;
      display      : inline-block;
    }
    .btn-green:hover { background: #2d6a4f; color: #d4a853; }
  </style>
</head>
<body>

<div class="container">
  <div class="error-card">

    <!-- Error icon -->
    <div class="error-icon">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#dc3545" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8"  x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
    </div>

    <!-- Error code if available -->
    <% if (typeof statusCode !== 'undefined') { %>
      <div class="error-code"><%= statusCode %></div>
    <% } %>

    <h5 class="error-title">Something went wrong</h5>

    <p class="error-message">
      <%= typeof message !== 'undefined' && message
            ? message
            : "An unexpected error occurred. Please try again." %>
    </p>

    <!-- Action buttons -->
    <div class="d-flex flex-column gap-2 align-items-center">
      <a href="javascript:history.back()" class="btn-green">
        Go Back
      </a>
      <a href="/dashboard" class="btn btn-link text-muted small mt-1">
        Back to Dashboard
      </a>
    </div>

  </div>
</div>

</body>
</html>
